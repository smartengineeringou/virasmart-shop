# -------- RFQ email delivery (Priority 1) --------
# Get an API key at https://resend.com/api-keys.
# When RESEND_API_KEY is NOT set, /api/quotation still returns 200 and the
# payload is logged to the server console (useful for local dev).
RESEND_API_KEY=

# Inbox that receives RFQ submissions.
RFQ_TO_EMAIL=info@virasmart.eu

# Verified sender in Resend. The brand domain (virasmart.eu) must be verified
# first at https://resend.com/domains — NOT the shop subdomain. Keep the
# sending identity on the apex so it matches the business's main email domain.
RFQ_FROM_EMAIL=Virasmart RFQ <rfq@virasmart.eu>

# -------- Shopify Storefront API (future) --------
# When both are set, lib/shopify/client.ts will switch from mock data to live
# Storefront API calls. Until then the mock catalogue is served.
SHOPIFY_STORE_DOMAIN=
SHOPIFY_STOREFRONT_TOKEN=
